name: Keep Alive

on:
  schedule:
    - cron: '0 * * * *'

jobs:
  ping:
    runs-on: ubuntu-latest
    steps:
      - uses: actions/checkout@v3
      - uses: actions/setup-node@v3
        with:
          node-version: '18'
      - run: npm install
      - run: node index.js
        env:
          APPWRITE_API_KEY: ${{ secrets.APPWRITE_API_KEY }}
